# Supabase Configuration
# Get these values from: https://app.supabase.com/project/[project-id]/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public API key (SAFE to expose)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Service Role Key (NEVER expose this publicly!)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Payment Integration (Future)
# VITE_STRIPE_PUBLIC_KEY=pk_live_...
# VITE_STRIPE_SECRET_KEY=sk_live_... (server-side only)

# Email Service (Future)
# VITE_SENDGRID_API_KEY=SG.xxxxx

# Analytics (Future)
# VITE_GA_MEASUREMENT_ID=G-xxxxxxxxxx

# App Configuration
VITE_APP_NAME=FashionUp
VITE_APP_URL=http://localhost:5173
VITE_API_TIMEOUT=30000
